/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    PARAMETER VALUES
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    input = "samplesheet.csv"
    buffer_size = [ 5000, 10000 ]
    forks = [ 1, 2, 4 ]
    repeat    = 10 // times to repeat each run
    cache     = "/nfs/production/flicek/ensembl/variation/data/VEP"
    cache_version = 115
    fasta     = "/nfs/production/flicek/ensembl/variation/data/fasta/Homo_sapiens.GRCh38.dna.primary_assembly.fa"
    vcf       = "/nfs/production/flicek/ensembl/variation/data/PlatinumGenomes/NA12878.vcf.gz"
    assembly  = "GRCh38"
    species   = "homo_sapiens"
}

process {

    withName: 'ENSEMBLVEP_VEP' {
        ext.args   = ""
        memory = 4.GB
    }

}

profiles {
    test {
        params {
            input = "samplesheet-test.csv"
            buffer_size = [ 5000, 10000 ]
            forks = [ 1 ]
        }
        executor {
            name = 'local'
        }
    }

    codon {
        params {
            max_memory = 360.GB
            max_cpus   = 48
            max_time   = 240.h
        }
        executor {
            name = 'slurm'
        }
    }
}

trace {
    enabled = true
    file = "reports/trace.txt"
    overwrite = true
    //fields = 'task_id,name,status,exit,realtime,%cpu,rss'
}

dag {
    enabled = true
    file = "reports/flowchart.html"
    overwrite = true
}

timeline {
    enabled = true
    file = "reports/timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "reports/report.html"
    overwrite = true
}
